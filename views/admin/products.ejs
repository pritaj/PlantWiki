<%- include('../partials/header') %>

<div class="row mb-4">
  <div class="col-12 d-flex justify-content-between align-items-center">
    <h2 class="text-success">🛒 Termékek kezelése</h2>
    <button
      class="btn btn-success"
      data-bs-toggle="modal"
      data-bs-target="#addProductModal"
    >
      + Új termék
    </button>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-success">
      <tr>
        <th>ID</th>
        <th>Név</th>
        <th>Kategória</th>
        <th>Ár</th>
        <th>Készlet</th>
        <th>Műveletek</th>
      </tr>
    </thead>
    <tbody id="products-tbody"></tbody>
  </table>
</div>

<!-- Új termék modal -->
<div class="modal fade" id="addProductModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Új termék hozzáadása</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">
        <div
          id="add-product-error"
          class="alert alert-danger"
          style="display: none"
        ></div>
        <div class="mb-3">
          <label class="form-label">Név</label>
          <input type="text" id="add-product-name" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Leírás</label>
          <textarea
            id="add-product-description"
            class="form-control"
            rows="3"
          ></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Ár (Ft)</label>
          <input type="number" id="add-product-price" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Készlet</label>
          <input type="number" id="add-product-stock" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Kategória</label>
          <select id="add-product-category" class="form-select">
            <option value="növény">Növény</option>
            <option value="tápszer">Tápszer</option>
            <option value="föld">Föld</option>
            <option value="kiegészítő">Kiegészítő</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Mégse
        </button>
        <button type="button" class="btn btn-success" onclick="addProduct()">
          Hozzáadás
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Szerkesztés modal -->
<div class="modal fade" id="editProductModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Termék szerkesztése</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="edit-product-id" />
        <div class="mb-3">
          <label class="form-label">Név</label>
          <input type="text" id="edit-product-name" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Leírás</label>
          <textarea
            id="edit-product-description"
            class="form-control"
            rows="3"
          ></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Ár (Ft)</label>
          <input type="number" id="edit-product-price" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Készlet</label>
          <input type="number" id="edit-product-stock" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Kategória</label>
          <select id="edit-product-category" class="form-select">
            <option value="növény">Növény</option>
            <option value="tápszer">Tápszer</option>
            <option value="föld">Föld</option>
            <option value="kiegészítő">Kiegészítő</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Mégse
        </button>
        <button type="button" class="btn btn-warning" onclick="editProduct()">
          Mentés
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
