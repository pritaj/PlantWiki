<%- include('../partials/header') %>

<div class="row mb-4">
  <div class="col-12 d-flex justify-content-between align-items-center">
    <h2 class="text-success">🌱 Növények kezelése</h2>
    <button
      class="btn btn-success"
      data-bs-toggle="modal"
      data-bs-target="#addPlantModal"
    >
      + Új növény
    </button>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-hover" id="plants-table">
    <thead class="table-success">
      <tr>
        <th>ID</th>
        <th>Név</th>
        <th>Latin név</th>
        <th>Típus</th>
        <th>Nehézség</th>
        <th>Műveletek</th>
      </tr>
    </thead>
    <tbody id="plants-tbody"></tbody>
  </table>
</div>

<!-- Új növény modal -->
<div class="modal fade" id="addPlantModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Új növény hozzáadása</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">
        <div
          id="add-error"
          class="alert alert-danger"
          style="display: none"
        ></div>
        <div class="mb-3">
          <label class="form-label">Név</label>
          <input type="text" id="add-name" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Latin név</label>
          <input type="text" id="add-latin" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Leírás</label>
          <textarea
            id="add-description"
            class="form-control"
            rows="3"
          ></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Típus</label>
          <select id="add-type" class="form-select">
            <option value="beltéri">Beltéri</option>
            <option value="kültéri">Kültéri</option>
            <option value="kaktusz">Kaktusz</option>
            <option value="vízinövény">Vízinövény</option>
            <option value="egyéb">Egyéb</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Nehézség</label>
          <select id="add-difficulty" class="form-select">
            <option value="kezdő">Kezdő</option>
            <option value="haladó">Haladó</option>
            <option value="expert">Expert</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Öntözési gyakoriság</label>
          <input
            type="text"
            id="add-watering"
            class="form-control"
            placeholder="pl. hetente egyszer"
          />
        </div>
        <div class="mb-3">
          <label class="form-label">Fényigény</label>
          <select id="add-sunlight" class="form-select">
            <option value="árnyékos">Árnyékos</option>
            <option value="félárnyékos">Félárnyékos</option>
            <option value="napos">Napos</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Mégse
        </button>
        <button type="button" class="btn btn-success" onclick="addPlant()">
          Hozzáadás
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Szerkesztés modal -->
<div class="modal fade" id="editPlantModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Növény szerkesztése</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="edit-plant-id" />
        <div class="mb-3">
          <label class="form-label">Név</label>
          <input type="text" id="edit-name" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Latin név</label>
          <input type="text" id="edit-latin" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Leírás</label>
          <textarea
            id="edit-description"
            class="form-control"
            rows="3"
          ></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Típus</label>
          <select id="edit-type" class="form-select">
            <option value="beltéri">Beltéri</option>
            <option value="kültéri">Kültéri</option>
            <option value="kaktusz">Kaktusz</option>
            <option value="vízinövény">Vízinövény</option>
            <option value="egyéb">Egyéb</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Nehézség</label>
          <select id="edit-difficulty" class="form-select">
            <option value="kezdő">Kezdő</option>
            <option value="haladó">Haladó</option>
            <option value="expert">Expert</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Öntözési gyakoriság</label>
          <input type="text" id="edit-watering" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Fényigény</label>
          <select id="edit-sunlight" class="form-select">
            <option value="árnyékos">Árnyékos</option>
            <option value="félárnyékos">Félárnyékos</option>
            <option value="napos">Napos</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Mégse
        </button>
        <button type="button" class="btn btn-warning" onclick="editPlant()">
          Mentés
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
