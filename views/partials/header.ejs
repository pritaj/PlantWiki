<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>🌿 PlantWiki</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/css/style.css" rel="stylesheet" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">🌿 PlantWiki</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navMenu"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link" href="/plants">Növények</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/shop">Webshop</a>
            </li>
            <li class="nav-item"><a class="nav-link" href="/wiki">Wiki</a></li>
            <li class="nav-item">
              <a class="nav-link" href="/nutrients">Tápanyag</a>
            </li>
          </ul>
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item me-2">
              <button
                class="btn btn-link nav-link"
                onclick="toggleDarkMode()"
                id="dark-mode-btn"
                style="text-decoration: none; font-size: 1.2rem"
              >
                🌙
              </button>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/favorites">❤️ </a>
            </li>
            <li class="nav-item me-2">
              <a
                class="nav-link position-relative"
                href="#"
                data-bs-toggle="modal"
                data-bs-target="#cartModal"
              >
                🛒
                <span
                  id="cart-badge"
                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="display: none"
                  >0</span
                >
              </a>
            </li>

            <div id="auth-nav" class="d-flex"></div>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Kosár modal -->
    <div class="modal fade" id="cartModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">🛒 Kosár</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>
          <div class="modal-body">
            <div id="cart-items"></div>
            <div class="border-top pt-3 mt-3">
              <div class="d-flex justify-content-between mb-3">
                <strong>Összesen:</strong>
                <strong class="text-success"
                  ><span id="cart-total">0</span> Ft</strong
                >
              </div>
              <div class="mb-3">
                <label class="form-label">Szállítási cím</label>
                <input
                  type="text"
                  id="shipping-address"
                  class="form-control"
                  placeholder="1234 Budapest, Példa utca 1."
                />
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-secondary"
              data-bs-dismiss="modal"
            >
              Bezárás
            </button>
            <button type="button" class="btn btn-success" onclick="checkout()">
              Rendelés leadása
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast értesítő -->

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
      <div
        id="cart-toast"
        class="toast align-items-center text-white bg-success border-0"
        role="alert"
      >
        <div class="d-flex">
          <div class="toast-body" id="cart-toast-msg">
            Termék hozzáadva a kosárhoz!
          </div>
          <button
            type="button"
            class="btn-close btn-close-white me-2 m-auto"
            data-bs-dismiss="toast"
          ></button>
        </div>
      </div>
    </div>

    <div class="container mt-4"></div>
  </body>
</html>
